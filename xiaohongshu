`services/ref_service.py`：

```python
from pathlib import Path


IMAGE_EXTS = {".png", ".jpg", ".jpeg", ".webp"}


def list_reference_images(ref_dir: str):
    root = Path(ref_dir)

    if not root.exists():
        raise FileNotFoundError(f"参考图文件夹不存在：{ref_dir}")

    images = [
        str(p)
        for p in root.rglob("*")
        if p.suffix.lower() in IMAGE_EXTS
    ]

    if not images:
        raise RuntimeError(f"参考图文件夹为空：{ref_dir}")

    return images


def list_reference_images_by_type(ref_dir: str):
    root = Path(ref_dir)

    result = {
        "cover": [],
        "content": [],
        "ending": []
    }

    for key in result.keys():
        subdir = root / key
        if subdir.exists():
            result[key] = [
                str(p)
                for p in subdir.rglob("*")
                if p.suffix.lower() in IMAGE_EXTS
            ]

    # 如果没有分类文件夹，就用全部图片兜底
    all_images = list_reference_images(ref_dir)

    for key in result.keys():
        if not result[key]:
            result[key] = all_images

    return result
```

图片生成时：

```python
from services.ref_service import list_reference_images_by_type


def pick_refs_for_page(ref_dir: str, page: dict):
    refs = list_reference_images_by_type(ref_dir)

    page_type = page.get("type", "content")

    if page_type == "cover":
        return refs["cover"]

    if page_type == "ending":
        return refs["ending"]

    return refs["content"]
