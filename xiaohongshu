### **七、Playwright 自动草稿脚本**

这里给你一个可改造的基础版本。由于小红书创作服务平台页面结构可能更新，选择器需要你第一次调试时根据实际页面微调。目标不是绕过限制，而是打开官方创作平台，复用你手动登录后的浏览器状态，自动上传图片和填入内容。

`automation/xhs_creator_bot.py`：

```python
from pathlib import Path
from playwright.sync_api import sync_playwright, TimeoutError as PlaywrightTimeoutError


XHS_PUBLISH_URL = "https://creator.xiaohongshu.com/publish/publish?source=official"


def create_xhs_draft(
    title: str,
    body: str,
    hashtags: list[str],
    image_paths: list[str],
    user_data_dir: str = "browser_profile/xhs",
    headless: bool = False
):
    """
    创建小红书草稿。
    注意：
    1. 不自动发布。
    2. 第一次运行需要人工扫码登录。
    3. 遇到验证码、风控、登录失效，脚本会停留，人工处理。
    4. 页面选择器可能需要根据实际页面调整。
    """

    image_paths = [str(Path(p).resolve()) for p in image_paths]

    for p in image_paths:
        if not Path(p).exists():
            raise FileNotFoundError(f"图片不存在：{p}")

    final_body = build_xhs_body(body, hashtags)

    with sync_playwright() as p:
        context = p.chromium.launch_persistent_context(
            user_data_dir=user_data_dir,
            headless=headless,
            viewport={"width": 1440, "height": 1000},
            args=[
                "--disable-blink-features=AutomationControlled"
            ]
        )

        page = context.new_page()
        page.goto(XHS_PUBLISH_URL, wait_until="domcontentloaded")

        print("已打开小红书创作平台。若未登录，请手动扫码登录。")

        wait_for_login_or_publish_page(page)

        upload_images(page, image_paths)
        fill_title(page, title)
        fill_body(page, final_body)

        print("草稿内容已填写完成。请在浏览器中人工检查。")
        print("确认无误后，你可以手动保存草稿或发布。")

        page.bring_to_front()

        # 不关闭浏览器，方便你继续人工操作
        input("检查完成后按回车结束脚本...")
        context.close()


def build_xhs_body(body: str, hashtags: list[str]) -> str:
    tag_text = " ".join([f"#{tag}" for tag in hashtags])
    return f"{body.strip()}\n\n{tag_text}"


def wait_for_login_or_publish_page(page):
    """
    等待进入发布页。
    如果需要扫码登录，给用户足够时间处理。
    """
    try:
        page.wait_for_load_state("networkidle", timeout=15000)
    except PlaywrightTimeoutError:
        pass

    # 给人工扫码登录留时间
    for _ in range(60):
        url = page.url
        if "publish" in url or "creator" in url:
            try:
                if page.locator("input[type='file']").count() > 0:
                    return
            except Exception:
                pass

        page.wait_for_timeout(1000)

    print("未检测到发布页文件上传入口，可能需要人工登录或页面结构已变化。")
    input("请手动完成登录并进入发布页面后，按回车继续...")


def upload_images(page, image_paths: list[str]):
    """
    上传图片。
    大多数发布页会有 input[type=file]。
    如果页面隐藏了 input，Playwright 仍然可以 set_input_files。
    """
    file_inputs = page.locator("input[type='file']")

    if file_inputs.count() == 0:
        raise RuntimeError("未找到图片上传 input[type='file']，需要检查页面结构。")

    file_input = file_inputs.first
    file_input.set_input_files(image_paths)

    print(f"已上传 {len(image_paths)} 张图片。")

    # 等待图片上传处理
    page.wait_for_timeout(5000)


def fill_title(page, title: str):
    """
    填写标题。
    选择器需要根据实际页面调整。
    """
    candidates = [
        "input[placeholder*='标题']",
        "textarea[placeholder*='标题']",
        "[contenteditable='true']"
    ]

    for selector in candidates:
        locator = page.locator(selector)
        if locator.count() > 0:
            try:
                locator.first.click()
                locator.first.fill(title)
                print("标题已填写。")
                return
            except Exception:
                continue

    raise RuntimeError("未找到标题输入框，需要根据页面结构调整选择器。")


def fill_body(page, body: str):
    """
    填写正文。
    选择器需要根据实际页面调整。
    """
    candidates = [
        "textarea[placeholder*='正文']",
        "textarea[placeholder*='描述']",
        "textarea[placeholder*='分享']",
        "div[contenteditable='true']"
    ]

    for selector in candidates:
        locator = page.locator(selector)
        if locator.count() > 0:
            try:
                # 如果第一个 contenteditable 是标题，可能需要选择第二个
                target = locator.nth(1) if locator.count() > 1 else locator.first
                target.click()
                target.fill(body)
                print("正文已填写。")
                return
            except Exception:
                continue

    raise RuntimeError("未找到正文输入框，需要根据页面结构调整选择器。")
```

这个脚本的关键点：

```text
1. 使用 launch_persistent_context 保存登录态。
2. 第一次运行时你手动扫码登录。
3. 只上传图片和填写内容，不点击发布。
4. 页面结构变化时，只需要改选择器。
5. 运行结束前暂停，方便你人工检查。
```

