REF_IMAGE_DIR=参考图
OUTPUT_DIR=assets/outputs

TEXT_MODEL_PROVIDER=openai_relay
TEXT_MODEL_NAME=gpt-5.5
TEXT_MODEL_ID=gpt-5.5
OPENAI_TEXT_BASE_URL=https://你的中转站地址/v1
# OPENAI_TEXT_API_KEY=如需和图片不同，填写文本中转站Key；不填则复用 OPENAI_IMAGE_API_KEY
OPENAI_TEXT_USE_ENV_PROXY=false

IMAGE_MODEL_PROVIDER=openai_relay
IMAGE_MODEL_NAME=gpt-image-2
IMAGE_MODEL_ID=gpt-image-2
OPENAI_IMAGE_BASE_URL=https://你的中转站地址/v1
OPENAI_IMAGE_API_KEY=请替换为你的中转站Key
OPENAI_IMAGE_USE_ENV_PROXY=false
OPENAI_IMAGE_FALLBACK_TO_GENERATION=true
OPENAI_IMAGE_RETRY_COUNT=1
OPENAI_IMAGE_RETRY_DELAY_SECONDS=2
OPENAI_IMAGE_USE_REFERENCE_IMAGES=false
IMAGE_SIZE=auto
IMAGE_OUTPUT_FORMAT=png
MAX_REF_IMAGES_PER_PAGE=3

XHS_BROWSER_PROFILE=browser_profile/xhs
XHS_HEADLESS=false
XHS_POST_FILL_WAIT_SECONDS=600
